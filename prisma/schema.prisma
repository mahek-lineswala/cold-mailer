generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  refreshToken String?
  accessToken  String?
  tokenExpiry  DateTime?
  createdAt    DateTime @default(now())
}